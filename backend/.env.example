# Application
APP_NAME=HomeGuide AI
DEBUG=true

# Database (SQLite default; switch to PostgreSQL later)
DATABASE_URL=sqlite:///./data/realestate.db

# OpenAI (required for POST /chat)
OPENAI_API_KEY=sk-your-key-here
OPENAI_CHAT_MODEL=gpt-4o-mini

# LangGraph checkpointer (SQLite file for conversation memory)
CHECKPOINT_DB_URL=sqlite:///./data/checkpoints.db

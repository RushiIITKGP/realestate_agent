# Application
APP_NAME=HomeGuide AI
DEBUG=true

# SQLite (default, semantic search uses in-Python ranking)
DATABASE_URL=sqlite:///./data/realestate.db

# PostgreSQL + pgvector (recommended for Phase 6 production)
# DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/realestate

CHECKPOINT_DB_URL=sqlite:///./data/checkpoints.db

# Google Gemini (required for /chat and embedding index)
GOOGLE_API_KEY=your-google-api-key-here
LLM_MODEL=gemini-3.1-flash-lite-preview
LLM_TEMPERATURE=0.7
EMBEDDING_MODEL=models/text-embedding-004
